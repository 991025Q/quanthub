# start-quanthub.ps1

Write-Host "`n========================================" -ForegroundColor Cyan
Write-Host "  QuantHub 完整启动脚本" -ForegroundColor Cyan
Write-Host "========================================`n" -ForegroundColor Cyan

# 1. 启动 Docker Desktop
Write-Host "[1/7] 启动 Docker Desktop..." -ForegroundColor Yellow
Start-Process "C:\Program Files\Docker\Docker\Docker Desktop.exe"
Write-Host "      等待 2-3 分钟..." -ForegroundColor Gray
Start-Sleep -Seconds 150

# 2. 验证 Docker
Write-Host "[2/7] 验证 Docker 状态..." -ForegroundColor Yellow
try {
    docker info | Out-Null
    if ($LASTEXITCODE -eq 0) {
        Write-Host "      ✓ Docker 正常运行" -ForegroundColor Green
    } else {
        Write-Host "      ✗ Docker 未就绪，请手动检查" -ForegroundColor Red
        exit 1
    }
} catch {
    Write-Host "      ✗ Docker 检查失败" -ForegroundColor Red
    exit 1
}

# 3. 进入项目目录
Write-Host "[3/7] 进入项目目录..." -ForegroundColor Yellow
cd D:\桌面\quanthub\quanthub

# 4. 清理旧容器
Write-Host "[4/7] 清理旧容器和数据..." -ForegroundColor Yellow
docker compose -f docker-compose.yml -f docker-compose.dev.yml down -v --remove-orphans 2>&1 | Out-Null

# 5. 启动服务
Write-Host "[5/7] 构建并启动服务（首次需要 5-8 分钟）..." -ForegroundColor Yellow
docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build

# 6. 等待服务启动
Write-Host "[6/7] 等待服务启动..." -ForegroundColor Yellow
for ($i = 1; $i -le 8; $i++) {
    Start-Sleep -Seconds 15
    Write-Host "      已等待 $($i * 15) 秒..." -ForegroundColor Gray
    
    # 检查 API 是否健康
    try {
        $response = Invoke-WebRequest -Uri "http://localhost:8000/health" -UseBasicParsing -TimeoutSec 2 -ErrorAction SilentlyContinue
        if ($response.StatusCode -eq 200) {
            Write-Host "      ✓ 后端 API 已就绪" -ForegroundColor Green
            break
        }
    } catch {}
}

# 7. 显示状态
Write-Host "[7/7] 检查服务状态..." -ForegroundColor Yellow
docker compose ps

# 完成信息
Write-Host "`n========================================" -ForegroundColor Green
Write-Host "  ✓ 启动完成！" -ForegroundColor Green
Write-Host "========================================" -ForegroundColor Green
Write-Host "`n📍 访问地址:" -ForegroundColor Cyan
Write-Host "   前端界面:  http://localhost:3000" -ForegroundColor White
Write-Host "   API 文档:  http://localhost:8000/docs" -ForegroundColor White
Write-Host "   MinIO 控制台: http://localhost:9001" -ForegroundColor White
Write-Host "             (用户名/密码: minioadmin/minioadmin)" -ForegroundColor Gray
Write-Host "`n📝 常用命令:" -ForegroundColor Cyan
Write-Host "   查看实时日志:  docker compose logs -f" -ForegroundColor Gray
Write-Host "   查看特定服务:  docker compose logs -f api" -ForegroundColor Gray
Write-Host "   停止所有服务:  docker compose down" -ForegroundColor Gray
Write-Host "   重启服务:      docker compose restart" -ForegroundColor Gray
Write-Host "   查看容器状态:  docker compose ps" -ForegroundColor Gray
Write-Host "`n" -ForegroundColor White